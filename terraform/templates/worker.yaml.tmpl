machine:
  registries:
    mirrors:
      docker.io:
        endpoints:
          - ${registry_mirror_endpoint}/v2/docker.io
        overridePath: true
      ghcr.io:
        endpoints:
          - ${registry_mirror_endpoint}/v2/ghcr.io
        overridePath: true
      registry.k8s.io:
        endpoints:
          - ${registry_mirror_endpoint}/v2/registry.k8s.io
        overridePath: true
      public.ecr.aws:
        endpoints:
          - ${registry_mirror_endpoint}/v2/public.ecr.aws
        overridePath: true
      quay.io:
        endpoints:
          - ${registry_mirror_endpoint}/v2/quay.io
        overridePath: true
  kubelet:
    extraArgs:
      cloud-provider: external
      rotate-server-certificates: true
      register-with-taints: "karpenter.sh/unregistered=:NoExecute"
    nodeIP:
      validSubnets:
%{ for subnet in validSubnets ~}
        - ${subnet}
%{ endfor ~}
  install:
    image: ${installer_image}
  features:
    hostDNS:
      enabled: true
      forwardKubeDNSToHost: false
cluster:
  network:
    podSubnets:
      - 10.233.0.0/18
      - fd85:ee78:d8a6:8607::1:0000/112
    serviceSubnets:
      - 10.233.64.0/18
      - fd85:ee78:d8a6:8607::1000/116 